# ARIA Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================================================
# REQUIRED: Anthropic Claude API
# ============================================================================
# Get your API key from: https://console.anthropic.com/account/keys
# Sign up for free at: https://console.anthropic.com/
# This key is used for LLM calls: ranking, summarization, newsletter drafting
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================================================
# REQUIRED: Gmail Setup
# ============================================================================
# Sender email address (must match Gmail account with OAuth credentials)
# This is the address newsletters will come from
GMAIL_SENDER_EMAIL=your-email@gmail.com

# Recipient email address (where newsletters are sent)
# Can be different from sender if desired
NEWSLETTER_RECIPIENT_EMAIL=recipient@example.com

# Note: Gmail OAuth credentials (gmail_credentials.json, gmail_token.json)
# are generated automatically on first run. See README.md for Gmail setup.

# ============================================================================
# LangSmith Observability & Tracing
# ============================================================================
# Get free account at: https://smith.langchain.com/
# Free tier: 5,000 traces/month (covers ~50 weekly runs)
# If not provided: system works fine without tracing
# With these keys: all LLM calls and graph execution traced to LangSmith dashboard

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT=ARIA
# Required only if your LangSmith API key belongs to multiple workspaces.
# Find it in LangSmith workspace settings.
# LANGSMITH_WORKSPACE_ID=<your-workspace-id>


# ============================================================================
# FREE API SOURCES (no credentials needed)
# ============================================================================
# These sources are already configured and require no setup:
# - RSS Feeds: Blogs you configure in config.py
# - Hacker News: Public Firebase API (news.ycombinator.com)
# - ArXiv: Public research papers API (arxiv.org)
# No API keys required for any of these.

# ============================================================================
# OPTIONAL: Development Settings
# ============================================================================
# Set to "development" to use mock APIs and cached responses (zero cost)
# Set to "production" to use real APIs
# ENVIRONMENT=development

# Database path (optional; defaults to ./newsletter.db)
# DATABASE_PATH=./newsletter.db

# Logging level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
