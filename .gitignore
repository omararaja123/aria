# ============================================================================
*.db
*.sqlite
*.sqlite3
newsletter.db
test.db

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
# Virtual Environments
# ============================================================================
venv/
env/
ENV/
env.bak/
venv.bak/
.venv

# ============================================================================
# IDEs & Editors
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ============================================================================
